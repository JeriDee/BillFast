generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  businessName  String?
  businessEmail String?
  businessPhone String?
  logoUrl       String?
  colors        String?
  footer        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clients       Client[]
  invoices      Invoice[]
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  invoices  Invoice[]
  createdAt DateTime  @default(now())
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id])

  businessName  String
  businessEmail String
  businessPhone String
  logoUrl       String?

  clientName    String
  clientEmail   String

  invoiceDate   String
  dueDate       String
  currency      String    @default("NGN")
  taxPercent    Float?
  discountPercent Float?
  notes         String?
  paymentTerms  String?
  colors        String?
  footer        String?

  items         String

  subtotal      Float
  taxAmount     Float?
  discountAmount Float?
  total         Float

  paid          Boolean   @default(false)
  paymentRef    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
